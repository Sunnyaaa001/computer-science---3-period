<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.whs.apiplatform.ai.mapper.AIChattingHistoryMapper">

    <insert id="insertHistory" parameterType="AIChattingHistory">
        insert into ai_chatting_history
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null and id != ''">id,</if>
            <if test="topicId != null and topicId != ''">topic_id,</if>
            <if test="aiContent != null and aiContent != ''">ai_content,</if>
            <if test="type != null and type != ''">`type`,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
            values
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="id != null and id != ''">#{id},</if>
            <if test="topicId != null and topicId != ''">#{topicId},</if>
            <if test="aiContent != null and aiContent != ''">#{aiContent},</if>
            <if test="type != null and type != ''">#{type},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <select id="selectHistoryList" resultType="com.whs.apiplatform.ai.domain.AIChattingHistory">
        select
        id as id,
        topic_id as topicId,
        ai_content as aiContent,
        `type` as type
        from
            ai_chatting_history
        where
            topic_id =  #{topicId}
        order by create_time
    </select>

    <delete id="deleteHistoryByTopicId">
        delete from ai_chatting_history where topic_id = #{topicId}
    </delete>
</mapper>